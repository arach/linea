{
  "name": "linea",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun server/dev.ts",
    "build": "bun run build:client && bun run build:ssr && bun run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build:server": "tsup server/index.ts --format esm --out-dir dist --target node22 --splitting false",
    "build:static": "vite build --outDir dist/static",
    "start": "NODE_ENV=production bun dist/index.js"
  },
  "dependencies": {
    "@arach/ora": "0.0.2",
    "@clerk/express": "^2.0.6",
    "@clerk/react": "^6.1.2",
    "@fontsource/fraunces": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@voxd/client": "0.2.0",
    "agentation": "^2.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "lucide-react": "^0.542.0",
    "motion": "^12.38.0",
    "pdfjs-dist": "^5.4.149",
    "postgres": "^3.4.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "tailwindcss": "^4.1.13",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
