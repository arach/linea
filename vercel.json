{
  "buildCommand": "bun run build",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/demo",
      "destination": "/"
    },
    {
      "source": "/demo/(.*)",
      "destination": "/"
    },
    {
      "source": "/playground",
      "destination": "/"
    },
    {
      "source": "/playground/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/vox-cache/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
